    "include": ["vitest.config.*", "playwright.config.*"],
    "compilerOptions": {
        "module": "preserve",
        "moduleResolution": "bundler",
        "noEmit": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.config.tsbuildinfo"
    }
}
