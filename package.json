{
    "name": "set-steps",
    "version": "0.5.0",
    "license": "MIT",
    "author": "Lennart Gerken",
    "description": "Automatically inject test steps into Playwright actions and extend core APIs with custom methods.",
    "keywords": [
        "e2e",
        "playwright",
        "report",
        "reporting",
        "test",
        "test-automation",
        "test-steps"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/lennartgerken/set-steps.git"
    },
    "bugs": {
        "url": "https://github.com/lennartgerken/set-steps/issues"
    },
    "type": "module",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "module": "./dist/index.js",
    "main": "./dist/index.cjs",
    "files": [
        "dist/index.js",
        "dist/index.cjs",
        "dist/index.d.ts"
    ],
    "scripts": {
        "pretty": "prettier . --write",
        "pretty-check": "prettier . --check",
        "lint": "eslint .",
        "build": "rollup -c",
        "test-type-check": "npx tsc -p ./tests/playwright/tsconfig.json --noEmit",
        "serve-test": "serve tests/playwright/public -l 3000",
        "test": "vitest run"
    },
    "peerDependencies": {
        "@playwright/test": "^1.56.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/node": "^24.12.2",
        "eslint": "^10.0.2",
        "prettier": "^3.6.2",
        "rollup": "^4.53.3",
        "rollup-plugin-dts": "^6.4.1",
        "serve": "^14.2.5",
        "tslib": "^2.8.1",
        "typescript-eslint": "^8.56.1",
        "vitest": "^4.0.13"
    }
}
